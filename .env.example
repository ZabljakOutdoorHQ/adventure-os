# AdventureHub read-only adapter — see docs/integrations/adventure-hub.md
# Authentication is an anonymous JWT (POST /api/tokens), so no secret is
# required for the read surface this repo implements.
ADVENTURE_HUB_BASE_URL=https://api.adventurehub.tech
ADVENTURE_HUB_ENV=production

# Plane read-only adapter — see docs/integrations/plane.md
# Mission Control's "Waiting for me" card stays in its disconnected state
# unless PLANE_ENABLED is exactly "true" AND both PLANE_API_KEY and
# PLANE_WORKSPACE_SLUG are set (lib/task-service-provider.ts).
PLANE_ENABLED=false
# PLANE_API_KEY is a real secret (generated at Workspace Settings > API
# Tokens in the Plane app). Never put a real value here or in any committed
# file — this is a placeholder for local .env only. Server-side only —
# never exposed to the browser (lib/task-service-provider.ts is guarded
# with `import "server-only"`).
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=
# Optional — only needed for a self-hosted Plane instance.
PLANE_API_BASE_URL=https://api.plane.so
